# Hermes Instance Environment Variables
# Copy to ~/your-agent/.hermes/.env and fill in values

# === REQUIRED ===
OPENROUTER_API_KEY=sk-or-...  # From https://openrouter.ai/keys

# === TELEGRAM (if using) ===
TELEGRAM_BOT_TOKEN=123456:ABC...  # From @BotFather
TELEGRAM_ALLOWED_USERS=docxology  # Or "allow all" for open access
TELEGRAM_HOME_CHANNEL=ActiveInference  # Default outbound channel

# === OPTIONAL API KEYS ===
# FAL_KEY=...           # Image generation (FAL)
# FIRECRAWL_API_KEY=... # Web scraping (Firecrawl)
# BROWSERBASE_API_KEY=... # Browser automation
# BROWSERBASE_PROJECT_ID=...\
# VOICE_TOOLS_OPENAI_KEY=... # OpenAI TTS/STT
# TINKER_API_KEY=...    # RL training
# WANDB_API_KEY=...     # Weights & Biases
# HONCHO_API_KEY=...    # Honcho memory

# === HERMES 3 API SERVER ===
# API_SERVER_ENABLED=true
# API_SERVER_KEY=your_secret_bearer_token
# API_SERVER_PORT=8000
# API_SERVER_HOST=0.0.0.0

# === OPTIONAL SETTINGS ===
# HERMES_MAX_ITERATIONS=90  # Max tool-calling turns
# TERMINAL_TIMEOUT=180      # Command timeout (seconds)
# TERMINAL_LIFETIME_SECONDS=300  # Container lifetime
