# Codomyrmex Agent Configurations
#
# This file serves as a template for all environment variables used by the 14
# provider integrations within the Codomyrmex ecosystem.
# 
# Copy this file to `.env` in your project root or `~/.codomyrmex/` and fill
# in the necessary API keys or paths for the agents you wish to utilize.

# -----------------------------------------------------------------------------
# API-Based Agents
# -----------------------------------------------------------------------------

# Claude (Anthropic)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Codex / o1 (OpenAI)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# DeepSeek Coder
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""

# Qwen-Coder (Alibaba DashScope)
# Get key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=""

# Perplexity (Online search-augmented LLM)
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=""

# OpenRouter (Model aggregator for free tier / specific LLMs)
# Used primarily by the fallback/routing providers in codomyrmex/llm
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# -----------------------------------------------------------------------------
# CLI-Based Agents
# -----------------------------------------------------------------------------
# These variables configure the absolute path or command name for CLI tools.
# They are optional if the binary is already available on your system $PATH.

# Jules CLI (Google)
# Source: internal/TBD
JULES_COMMAND="jules"

# OpenCode CLI
# Source: https://github.com/opencode/opencode-cli
OPENCODE_COMMAND="opencode"

# Gemini CLI (Google)
# Source: internal/TBD
GEMINI_COMMAND="gemini"

# Mistral Vibe CLI
MISTRAL_VIBE_COMMAND="vibe"

# Every Code CLI
EVERY_CODE_COMMAND="code"

# Hermes Agent CLI (NousResearch)
# Source: https://github.com/NousResearch/hermes-agent
HERMES_COMMAND="hermes"

# -----------------------------------------------------------------------------
# Local Agents
# -----------------------------------------------------------------------------

# Ollama API Base URL (Local LLM server)
# Download: https://ollama.com/
OLLAMA_BASE_URL="http://localhost:11434"
