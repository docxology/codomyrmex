# PAI PM Server — Environment Configuration
# Copy to .env and fill in your values.

# ── Server ──
PAI_PM_PORT=8889

# ── PAI State ──
# PAI_DIR=~/.claude
# PAI_STATE_DIR=$PAI_DIR/MEMORY/STATE
# PAI_SYNC_DIR=$PAI_STATE_DIR/sync

# ── GitHub ──
GITHUB_DEFAULT_OWNER=your-org-or-username
# GITHUB_TOKEN=ghp_...  (or use `gh auth login`)

# ── Google Calendar ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Gmail ──
# Uses same GOOGLE_CLIENT_ID/SECRET by default, or set separately:
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# ── AgentMail ──
AGENTMAIL_API_KEY=your-agentmail-api-key
AGENTMAIL_DEFAULT_INBOX=your-inbox@agentmail.to

# ── Calendar Sync ──
# CALENDAR_DEFAULT_ATTENDEE=your-email@gmail.com
